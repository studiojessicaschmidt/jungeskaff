---
/*
 * Impressum
 *
 * Pflicht-Seite nach § 5 TMG. Inhaltlich absichtlich leer, weil die
 * Verantwortung für Richtigkeit und Vollständigkeit beim Anbieter
 * liegt. Der Platzhalter-Text dokumentiert, welche Angaben erwartet
 * werden und warum hier kein Default-Text steht.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
---

<BaseLayout
  title="Impressum, [KUNDE: Markenname]"
  description="Impressum und Anbieterkennzeichnung nach § 5 TMG."
>
  <section class="section" aria-labelledby="impressum-heading">
    <Container size="narrow">
      <Heading level={1} id="impressum-heading">Impressum</Heading>

      {/* Pflichtangaben des Diensteanbieters nach § 5 DDG (früher § 5 TMG). */}
      <h2 class="impressum__subheading">Angaben gemäß § 5 DDG</h2>
      <p class="impressum__block">
        Junges KaFF<br />
        In d. Bredenau 83<br />
        28870 Ottersberg-Fischerhude
      </p>

      {/* Direkte Kontaktmöglichkeiten, mindestens E-Mail ist Pflicht. */}
      <h2 class="impressum__subheading">Kontakt</h2>
      <p class="impressum__block">
        E-Mail: <a href="mailto:info@jungeskaff.de">info@jungeskaff.de</a>
      </p>

      {/*
        Verantwortlich für redaktionelle Inhalte (Ausstellungs-Texte,
        Presse) nach § 18 Abs. 2 MStV. Muss eine erreichbare natürliche
        Person mit ladungsfähiger Anschrift sein.
      */}
      <h2 class="impressum__subheading">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h2>
      <p class="impressum__block">
        Chantal Knickmeyer<br />
        In d. Bredenau 83<br />
        28870 Ottersberg-Fischerhude
      </p>
    </Container>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-2xl);
  }

  .impressum__subheading {
    margin-block-start: var(--space-xl);
    margin-block-end: var(--space-2xs);
    font-size: var(--text-lg);
  }

  .impressum__block {
    margin: 0;
  }
</style>
