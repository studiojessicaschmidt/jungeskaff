---
/**
 * Tag
 *
 * Kleines Label für Kategorien, Status-Hinweise oder Meta-Informationen.
 * Immer als <span> gerendert, da es kein interaktives Element ist.
 * Für klickbare Tags bitte stattdessen einen Link mit Tag-Optik bauen.
 */

import type { HTMLAttributes } from "astro/types";

type TagVariant = "default" | "subtle" | "accent";

interface Props extends HTMLAttributes<"span"> {
  /** Visuelle Variante. Default "default". */
  variant?: TagVariant;
}

const { variant = "default", class: extraClass, ...rest } = Astro.props;
---

<span class:list={["tag", `tag--${variant}`, extraClass]} {...rest}>
  <slot />
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3xs);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .tag--default {
    background-color: var(--color-surface-alt);
    color: var(--color-text);
  }

  .tag--subtle {
    background-color: var(--color-surface);
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }

  .tag--accent {
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }
</style>
