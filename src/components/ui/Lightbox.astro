---
/**
 * Lightbox
 *
 * Modal-Dialog (HTML <dialog>) für die Galerie. Wird einmal pro Seite
 * in BaseLayout.astro eingebunden und vom Galerie-Script angesteuert.
 *
 * Funktionsweise:
 * - Klick auf ein Galerie-Bild öffnet den Dialog mit dem geklickten Bild
 * - Pfeiltasten links/rechts und Prev/Next-Buttons navigieren
 * - Esc schließt (HTML <dialog> nativ)
 * - Klick auf Backdrop (ausserhalb des Bildes) schliesst
 * - Bild wird in voller Originalfarbe gezeigt, kein Duotone-Filter
 *
 * Die Texte für die Buttons werden via Props übergeben, damit der
 * Sprachumschalter (Phase 2) sie austauschen kann.
 */

interface Props {
  /** Aria-Label für den Schließen-Button */
  closeLabel: string;
  /** Aria-Label für vorheriges Bild */
  prevLabel: string;
  /** Aria-Label für nächstes Bild */
  nextLabel: string;
}

const { closeLabel, prevLabel, nextLabel } = Astro.props;
---

<dialog class="lightbox" data-lightbox aria-label="Bild-Vorschau">
  <button
    type="button"
    class="lightbox__button lightbox__close"
    data-lightbox-close
    aria-label={closeLabel}
  >
    {/* Schließen-Icon: einfaches X */}
    <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
      <path d="M6 6 L18 18 M18 6 L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </button>

  <button
    type="button"
    class="lightbox__button lightbox__prev"
    data-lightbox-prev
    aria-label={prevLabel}
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
      <path d="M15 6 L9 12 L15 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    </svg>
  </button>

  <button
    type="button"
    class="lightbox__button lightbox__next"
    data-lightbox-next
    aria-label={nextLabel}
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
      <path d="M9 6 L15 12 L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    </svg>
  </button>

  {/* Bild-Container: figure mit img + caption */}
  <figure class="lightbox__figure">
    <img class="lightbox__image" data-lightbox-image src="" alt="" />
    <figcaption class="lightbox__caption" data-lightbox-caption></figcaption>
  </figure>
</dialog>

<script>
  import "../../scripts/lightbox";
</script>

<style>
  .lightbox {
    /* Native dialog-Defaults überschreiben */
    border: 0;
    padding: 0;
    margin: 0;
    background: transparent;
    color: var(--color-text);
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    inset: 0;
  }

  .lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
  }

  /* ------------------------------------------------------------------
   * Bild zentriert, max 90% Viewport-Größe damit Buttons Platz haben.
   * ------------------------------------------------------------------ */

  .lightbox__figure {
    position: absolute;
    inset: 0;
    margin: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .lightbox__image {
    max-width: min(95vw, 1600px);
    max-height: 85vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    pointer-events: auto;
  }

  .lightbox__caption {
    /* Versteckt – könnte später für Bildbeschriftung genutzt werden */
    position: absolute;
    inset-block-end: var(--space-sm);
    inset-inline-start: 50%;
    transform: translateX(-50%);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.7;
  }

  /* ------------------------------------------------------------------
   * Buttons
   * ------------------------------------------------------------------ */

  .lightbox__button {
    position: absolute;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--touch-target-min);
    height: var(--touch-target-min);
    background: rgba(0, 0, 0, 0.55);
    border: 0;
    border-radius: var(--radius-pill);
    color: var(--color-text);
    cursor: pointer;
    /* z-index über dem Bild — sonst werden die Buttons im Mobile-
       Viewport (Bild fast vollständige Viewport-Breite) verdeckt. */
    z-index: 1;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .lightbox__button:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .lightbox__button:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .lightbox__close {
    inset-block-start: var(--space-md);
    inset-inline-end: var(--space-md);
  }

  .lightbox__prev {
    inset-block-start: 50%;
    inset-inline-start: var(--space-md);
    transform: translateY(-50%);
  }

  .lightbox__next {
    inset-block-start: 50%;
    inset-inline-end: var(--space-md);
    transform: translateY(-50%);
  }

  /* Touch-Buttons grösser auf Tablet/Desktop */
  @media (min-width: 48em) {
    .lightbox__button {
      width: 3rem;
      height: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox__button {
      transition: none;
    }
  }
</style>
