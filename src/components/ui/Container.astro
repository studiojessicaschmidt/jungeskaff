---
/**
 * Container
 *
 * Rahmen-Komponente mit maximaler Lesebreite und horizontalem Innenabstand.
 * Wird um Seiten-Sections gelegt, damit Inhalte auf breiten Bildschirmen
 * nicht unbegrenzt fließen. Alle Breiten und Abstände stammen aus Tokens.
 */

import type { HTMLAttributes } from "astro/types";

/** Semantische Root-Tags, die als Container sinnvoll sind. */
type ContainerTag = "div" | "section" | "article" | "main" | "header" | "footer" | "nav" | "aside";

/**
 * Max-Width-Variante.
 * - narrow:  schmaler Content, z. B. CTA-Sections
 * - default: Standard-Seitenbreite
 * - wide:    Dashboard-artige Seiten, Galerien
 * - prose:   Fließtext mit optimaler Zeilenlänge (ca. 65 Zeichen)
 * - full:    keine Begrenzung (randlos, ohne horizontales Padding)
 */
type ContainerSize = "narrow" | "default" | "wide" | "prose" | "full";

interface Props extends HTMLAttributes<"div"> {
  /** HTML-Tag des Root-Elements. Default "div". */
  as?: ContainerTag;
  /** Max-Breite. Default "default" nutzt --container-default aus den Tokens. */
  size?: ContainerSize;
}

const { as: Tag = "div", size = "default", class: extraClass, ...rest } = Astro.props;
---

<Tag class:list={["container", `container--${size}`, extraClass]} {...rest}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--container-pad-inline);
  }

  .container--narrow {
    max-width: var(--container-narrow);
  }

  .container--default {
    max-width: var(--container-default);
  }

  .container--wide {
    max-width: var(--container-wide);
  }

  /*
   * Fließtext-Container, ca. 65 Zeichen pro Zeile. Für Seiten wie
   * Impressum, Datenschutz, Artikel-Inhalte, bei denen Lesbarkeit
   * über maximale Breite zählt.
   */
  .container--prose {
    max-width: var(--container-prose);
  }

  .container--full {
    max-width: none;
    padding-inline: 0;
  }
</style>
