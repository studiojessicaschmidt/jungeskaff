{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"../**/*.{astro,ts,tsx,js,jsx,css,md,json}\" --config ../.prettierrc --ignore-path ../.prettierignore",
    "format:check": "prettier --check \"../**/*.{astro,ts,tsx,js,jsx,css,md,json}\" --config ../.prettierrc --ignore-path ../.prettierignore"
  },
  "dependencies": {
    "astro": "^6.1.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
